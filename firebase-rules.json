{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        "status": {
          ".write": "auth != null"
        }
      }
    },
    "calls": {
      ".read": "auth != null",
      ".indexOn": ["calleeId"],
      "$callId": {
        ".write": "auth != null"
      }
    },
    "signaling": {
      "$callId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
